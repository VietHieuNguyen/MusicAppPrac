extends ../../layouts/default.pug
include ../../mixins/icons.pug

block main
  .song-detail-page
    //- Hero Section with gradient background
    .song-detail-hero
      .song-detail-hero__gradient(style=song.avatar ? `background-image: url(${song.avatar})` : '')
      .song-detail-hero__overlay
      .song-detail-hero__content
        .song-detail-hero__cover
          if song.avatar
            img(src=song.avatar alt=song.title)
          else
            .song-detail-hero__cover-placeholder
              +icon-play()
        .song-detail-hero__info
          span.song-detail-hero__type Bài hát
          h1.song-detail-hero__title= song.title
          .song-detail-hero__meta
            if singer && singer.avatar
              img.song-detail-hero__artist-avatar(src=singer.avatar alt=singer.fullName)
            if singer
              a.song-detail-hero__artist(href="#")= singer.fullName
            if topic
              span.song-detail-hero__separator •
              span= topic.title
            if song.createdAt
              span.song-detail-hero__separator •
              - var year = new Date(song.createdAt).getFullYear()
              span= year
            if song.like
              span.song-detail-hero__separator •
              span #{song.like.toLocaleString()} likes

    //- Action Buttons
    .song-detail-actions
      button.btn-play-big#btnDetailPlay(
        data-song=song
        data-singer=singer
      )
        +icon-play()
      button.btn-action-circle.btn-action-circle--lg(title="Add to playlist")
        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
          path(d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z")
      button.btn-action-circle.btn-action-circle--lg(title="Like" button-like=song.id)
        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512")
          path(d="M171.5 38.8C192.3 4 236.5-10 274 7.6l7.2 3.8C316 32.3 330 76.5 312.4 114l0 0-14.1 30 109.7 0 7.4 .4c36.3 3.7 64.6 34.4 64.6 71.6 0 13.2-3.6 25.4-9.8 36 6.1 10.6 9.7 22.8 9.8 36 0 18.3-6.9 34.8-18 47.5 1.3 5.3 2 10.8 2 16.5 0 25.1-12.9 47-32.2 59.9-1.9 35.5-29.4 64.2-64.4 67.7l-7.4 .4-104.1 0c-18 0-35.9-3.4-52.6-9.9l-7.1-3-.7-.3-6.6-3.2-.7-.3-12.2-6.5c-12.3-6.5-23.3-14.7-32.9-24.1-4.1 26.9-27.3 47.4-55.3 47.4l-32 0c-30.9 0-56-25.1-56-56L0 200c0-30.9 25.1-56 56-56l32 0c10.8 0 20.9 3.1 29.5 8.5l50.1-106.5 .6-1.2 2.7-5 .6-.9zM56 192c-4.4 0-8 3.6-8 8l0 224c0 4.4 3.6 8 8 8l32 0c4.4 0 8-3.6 8-8l0-224c0-4.4-3.6-8-8-8l-32 0zM253.6 51c-14.8-6.9-32.3-1.6-40.7 12l-2.2 4-56.8 120.9c-3.5 7.5-5.5 15.5-6 23.7l-.1 4.2 0 112.9 .2 7.9c2.4 32.7 21.4 62.1 50.7 77.7l11.5 6.1 6.3 3.1c12.4 5.6 25.8 8.5 39.4 8.5l104.1 0 2.4-.1c12.1-1.2 21.6-11.5 21.6-23.9l-.2-2.6c-.1-.9-.2-1.7-.4-2.6-2.7-12.1 4.3-24.2 16-28 9.7-3.1 16.6-12.2 16.6-22.8 0-4.3-1.1-8.2-3.1-11.8-6.3-11.1-2.8-25.2 8-32 6.8-4.3 11.2-11.8 11.2-20.2 0-7.1-3.1-13.5-8.2-18-5.2-4.6-8.2-11.1-8.2-18s3-13.4 8.2-18c5.1-4.5 8.2-10.9 8.2-18l-.1-2.4c-1.1-11.3-10.1-20.3-21.4-21.4l-2.4-.1-147.5 0c-8.2 0-15.8-4.2-20.2-11.1-4.4-6.9-5-15.7-1.5-23.1L269 93.6c7-15 1.4-32.7-12.5-41L253.6 51z")
      button.btn-action-circle.btn-action-circle--lg(title="More")
        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
          path(d="M6 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm12 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z")

    //- Main Content: Lyrics + Artist
    .song-detail-body
      //- Lyrics Section
      .song-detail-lyrics
        if song.lyrics
          h2.song-detail-lyrics__title Lyrics
          .song-detail-lyrics__content
            - var lines = song.lyrics.split('\n')
            each line, idx in lines
              if line.trim()
                p.lyrics-line(data-line=idx)= line
              else
                br
        else
          .song-detail-lyrics__empty
            p Chưa có lyrics cho bài hát này.

      //- Artist Card
      if singer
        .song-detail-artist
          .song-detail-artist__avatar
            if singer.avatar
              img(src=singer.avatar alt=singer.fullName)
            else
              .song-detail-artist__avatar-placeholder
                svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
                  path(d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z")
          .song-detail-artist__info
            span.song-detail-artist__label Artist
            h3.song-detail-artist__name= singer.fullName


